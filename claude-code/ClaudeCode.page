<script>
var CC = {
  pollTimer: null,
  busy: false,
  csrfToken: '<?= $csrf_token ?>'
};

function ccTab(el, id) {
  document.querySelectorAll('.cc-tab').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.cc-panel').forEach(function(p){ p.classList.remove('active'); });
  el.classList.add('active');
  document.getElementById(id).classList.add('active');
}

function formatJson(editorId, errId) {
  var el = document.getElementById(editorId);
  var err = document.getElementById(errId);
  try {
    var obj = JSON.parse(el.value);
    el.value = JSON.stringify(obj, null, 2);
    err.style.display = 'none';
    el.classList.remove('error');
  } catch(e) {
    err.textContent = 'Invalid JSON: ' + e.message;
    err.style.display = 'block';
    el.classList.add('error');
  }
}

function ajaxSave(action, editorId, errId, savedId) {
  var el  = document.getElementById(editorId);
  var err = document.getElementById(errId);
  var sav = document.getElementById(savedId);
  try { JSON.parse(el.value); } catch(e) {
    err.textContent = 'Invalid JSON: ' + e.message;
    err.style.display = 'block';
    el.classList.add('error');
    return;
  }
  err.style.display = 'none';
  el.classList.remove('error');
  var params = new URLSearchParams();
  params.append('action', action);
  if (CC.csrfToken && CC.csrfToken !== '') {
    params.append('csrf_token', CC.csrfToken);
  }
  params.append('content', el.value);
  fetch('/plugins/claude-code/action.php?' + params.toString(), { method:'GET' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (d.ok) {
        sav.style.display = 'inline';
        setTimeout(function(){ sav.style.display = 'none'; }, 3000);
      } else {
        err.textContent = 'Save failed: ' + (d.error || 'unknown');
        err.style.display = 'block';
      }
    })
    .catch(function(e){
      err.textContent = 'Request failed: ' + e.message;
      err.style.display = 'block';
    });
}

