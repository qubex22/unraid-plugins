/* ---- action runner + live progress ---- */
function setButtonsDisabled(state) {
  document.querySelectorAll('#cc-actions .cc-btn').forEach(function(b){ b.disabled = state; });
  document.getElementById('cc-cancel').style.display = state ? '' : 'none';
}

function showProgress(title, state) {
  var box = document.getElementById('cc-progress');
  box.style.display = '';
  document.getElementById('cc-prog-title').textContent = title;
  document.getElementById('cc-prog-state').textContent = state;
  document.getElementById('cc-prog-bar').style.display = (state === 'running') ? '' : 'none';
}

function runAction(name, confirmMsg) {
  if (CC.busy) return;
  if (confirmMsg && !confirm(confirmMsg)) return;
  CC.busy = true;
  setButtonsDisabled(true);
  showProgress(name.charAt(0).toUpperCase() + name.slice(1) + '…', 'running');
  document.getElementById('cc-prog-log').textContent = '(starting…)';
  var params = new URLSearchParams();
  params.append('action', 'start');
  if (CC.csrfToken && CC.csrfToken !== '') {
    params.append('csrf_token', CC.csrfToken);
  }
  params.append('name', name);
  fetch('/plugins/claude-code/action.php?' + params.toString(), { method:'GET' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (!d.ok) {
        CC.busy = false;
        setButtonsDisabled(false);
        showProgress('Failed', 'error');
        document.getElementById('cc-prog-log').textContent = 'Error: ' + (d.error || 'unknown');
        return;
      }
      pollProgress();
    })
    .catch(function(e){
      CC.busy = false;
      setButtonsDisabled(false);
      showProgress('Failed', 'error');
      document.getElementById('cc-prog-log').textContent = 'Request failed: ' + e.message;
      if (e.message.includes("JSON") || e.message.includes("parse") || e.message.includes("timeout") || e.message.includes("Gateway")) {
        document.getElementById("nginx-warning").style.display = "block";
      }
    });
}

function pollProgress() {
  clearTimeout(CC.pollTimer);
  var params = new URLSearchParams();
  params.append('action', 'progress');
  if (CC.csrfToken && CC.csrfToken !== '') {
    params.append('csrf_token', CC.csrfToken);
  }
  fetch('/plugins/claude-code/action.php?' + params.toString(), { method:'GET' })
    .then(function(r){ return r.json(); })
    .then(function(d){
      var log = document.getElementById('cc-prog-log');
      log.textContent = d.log || '(no output yet)';
      log.scrollTop = log.scrollHeight;
      if (d.running) {
        CC.pollTimer = setTimeout(pollProgress, 1000);
      } else {
        CC.busy = false;
        setButtonsDisabled(false);
        if (d.exit === 0) {
          showProgress('Completed successfully', 'done');
          setTimeout(function(){ location.reload(); }, 1500);
        } else {
          showProgress('Finished (exit code ' + d.exit + ')', 'error');
          log.textContent += '\n\n>>> action exited with code ' + d.exit + ' — see Error Log tab for details <<<';
        }
      }
    })
    .catch(function(){ CC.pollTimer = setTimeout(pollProgress, 2000); });
}

function cancelAction() {
  var params = new URLSearchParams();
  params.append('action', 'cancel');
  if (CC.csrfToken && CC.csrfToken !== '') {
    params.append('csrf_token', CC.csrfToken);
  }
  fetch('/plugins/claude-code/action.php?' + params.toString(), { method:'GET' })
    .then(function(r){ return r.json(); })
    .then(function(){
      clearTimeout(CC.pollTimer);
      CC.busy = false;
      setButtonsDisabled(false);
      showProgress('Cancelled', 'done');
    });
}

function showNginxFix(e) {
  e.preventDefault();
  var html = "<div style=\\"background:#1a1a1a;padding:16px;border-radius:6px;border:1px solid #444;font-size:13px;color:#eee;margin-top:16px">
<h3 style="margin:0 0 10px;color:#ff6b6b">Fix Required: nginx Configuration</h3>
<p><b>Issue:</b> Unraid global auth middleware times out for this plugin action endpoint.</p>
<p><b>Solution:</b> Run these commands as root in a terminal:</p>
<pre style="background:#000;padding:10px;border-radius:4px;font-family:monospace;font-size:12px;margin:8px 0">
# Add nginx location configuration to bypass auth_request
cat >> /etc/nginx/conf.d/locations.conf << EOF
# Claude Code plugin nginx configuration
location ^~ /plugins/claude-code/action.php {
  auth_request off;
  include fastcgi_params;
  fastcgi_read_timeout 300;
  fastcgi_send_timeout 300;
}
EOF

# Test and reload nginx
nginx -t && nginx -s reload</pre>
<p><b>Note:</b> This modifies a core Unraid file. The change is safe but may be overwritten during Unraid updates.</p>
<p><b>Alternative:</b> Use the command line: <code>bash /boot/config/plugins/claude-code/install-claude.sh</code></p>
</div>";
  var existing = document.getElementById("nginx-instructions");
  if (existing) {
    existing.style.display = existing.style.display === "none" ? "block" : "none";
  } else {
    var div = document.createElement("div");
    div.id = "nginx-instructions";
    div.innerHTML = html;
    document.getElementById("nginx-warning").parentNode.insertBefore(div, document.getElementById("nginx-warning").nextSibling);
  }
}
