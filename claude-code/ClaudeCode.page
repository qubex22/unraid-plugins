        'allow' => [],
        'deny'  => ['Read(./.env)', 'Read(./.env.*)'],
    ],
    'spinnerTipsEnabled' => false,
    'attribution' => ['commits' => true, 'pullRequests' => true],
];
$settingsJson = file_exists($settingsFile)
    ? file_get_contents($settingsFile)
    : json_encode($defaultSettings, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);

$defaultMcp = [
    'mcpServers' => [
        'sequential-thinking' => [
            'type'    => 'stdio',
            'command' => 'npx',
            'args'    => ['-y', '@modelcontextprotocol/server-sequential-thinking'],
