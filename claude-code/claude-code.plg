<?xml version='1.0' standalone='yes'?>

<!DOCTYPE PLUGIN [
<!ENTITY name      "claude-code">
<!ENTITY author    "community">
<!ENTITY version   "2025.06.24">
<!ENTITY pluginURL "https://raw.githubusercontent.com/qubex22/unraid-plugins/refs/heads/main/claude-code/claude-code.plg">
<!ENTITY pkgURL    "https://raw.githubusercontent.com/qubex22/unraid-plugins/refs/heads/main/claude-code">
<!ENTITY plgPATH   "/boot/config/plugins/&name;">
<!ENTITY plgNAME   "&name;-&version;-x86_64-1">
<!ENTITY emhttp    "/usr/local/emhttp/plugins/&name;">
]>

<PLUGIN name="&name;" author="&author;" version="&version;" pluginURL="&pluginURL;" min="6.10.0" support="https://forums.unraid.net">

<CHANGES>
###&version;
- Initial release
- Installs Claude Code with full persistence across reboots
- WebGUI page under Settings with settings.json editor, MCP config, env var reference, error log
- Stores binary and config on /boot (USB), restores symlinks on every boot via /boot/config/go
</CHANGES>

<!-- Download WebGUI package -->
<FILE Name="&plgPATH;/&plgNAME;.txz">
<URL>&pkgURL;/&plgNAME;.txz</URL>
</FILE>

<FILE Name="&plgPATH;/&plgNAME;.md5">
<URL>&pkgURL;/&plgNAME;.md5</URL>
</FILE>

<!-- Boot-time symlink restore script -->
<FILE Name="&plgPATH;/rc.claude-code" Mode="0755">
<INLINE>
#!/bin/bash
PERSIST="&plgPATH;/persist"
LOCAL_BIN="/root/.local/bin"
LOCAL_SHARE="/root/.local/share/claude"
CLAUDE_CFG="/root/.claude"

log() { logger -t "claude-code" "$*"; }

start() {
  [ ! -f "$PERSIST/bin/claude" ] &amp;&amp; log "Not installed. Use Settings/ClaudeCode to install." &amp;&amp; return 0
  log "Restoring symlinks from $PERSIST..."
  mkdir -p "$LOCAL_BIN" "/root/.local/share"
  ln -sf "$PERSIST/bin/claude" "$LOCAL_BIN/claude"
  chmod +x "$PERSIST/bin/claude"
  if [ -d "$PERSIST/share" ] &amp;&amp; [ ! -L "$LOCAL_SHARE" ]; then
    rm -rf "$LOCAL_SHARE"; ln -sf "$PERSIST/share" "$LOCAL_SHARE"
  fi
  if [ -d "$PERSIST/cfg" ] &amp;&amp; [ ! -L "$CLAUDE_CFG" ]; then
    rm -rf "$CLAUDE_CFG"; ln -sf "$PERSIST/cfg" "$CLAUDE_CFG"
  fi
  grep -q ".local/bin" /root/.bashrc 2>/dev/null || echo 'export PATH="$HOME/.local/bin:$PATH"' >> /root/.bashrc
  log "Claude Code ready."
}

stop() {
  log "Removing symlinks..."
  [ -L "$LOCAL_BIN/claude" ] &amp;&amp; rm -f "$LOCAL_BIN/claude"
  [ -L "$LOCAL_SHARE" ]      &amp;&amp; rm -f "$LOCAL_SHARE"
  [ -L "$CLAUDE_CFG" ]       &amp;&amp; rm -f "$CLAUDE_CFG"
}

case "$1" in
  start) start ;;
  stop)  stop  ;;
  *) echo "Usage: $0 {start|stop}" ;;
esac
</INLINE>
</FILE>

<!-- One-time install script -->
<FILE Name="&plgPATH;/install-claude.sh" Mode="0755">
<INLINE>
#!/bin/bash
PERSIST="&plgPATH;/persist"
LOCAL_BIN="/root/.local/bin"
LOCAL_SHARE="/root/.local/share/claude"
CLAUDE_CFG="/root/.claude"

log() { logger -t "claude-code" "$*"; echo "[claude-code] $*"; }

[ -f "$PERSIST/bin/claude" ] &amp;&amp; log "Already installed." &amp;&amp; exit 0

log "Creating persistent directories on /boot..."
mkdir -p "$PERSIST/bin" "$PERSIST/share" "$PERSIST/cfg"
mkdir -p "$LOCAL_BIN" "/root/.local/share"

log "Downloading Claude Code via official installer..."
export PATH="/root/.local/bin:$PATH"
curl -fsSL https://claude.ai/install.sh | bash
RC=$?
[ $RC -ne 0 ] &amp;&amp; log "Install failed (exit $RC)" &amp;&amp; exit 1

log "Moving files to persistent storage on /boot..."
[ -f "$LOCAL_BIN/claude" ] &amp;&amp; cp -a "$LOCAL_BIN/claude" "$PERSIST/bin/claude" &amp;&amp; chmod +x "$PERSIST/bin/claude"
if [ -d "$LOCAL_SHARE" ] &amp;&amp; [ ! -L "$LOCAL_SHARE" ]; then
  cp -a "$LOCAL_SHARE/." "$PERSIST/share/" 2>/dev/null; rm -rf "$LOCAL_SHARE"
fi
if [ -d "$CLAUDE_CFG" ] &amp;&amp; [ ! -L "$CLAUDE_CFG" ]; then
  cp -a "$CLAUDE_CFG/." "$PERSIST/cfg/" 2>/dev/null; rm -rf "$CLAUDE_CFG"
fi

bash "&plgPATH;/rc.claude-code" start
log "Install complete. Open a terminal and run: claude"
</INLINE>
</FILE>

<!-- Uninstall script -->
<FILE Name="&plgPATH;/uninstall-claude.sh" Mode="0755">
<INLINE>
#!/bin/bash
log() { logger -t "claude-code" "$*"; echo "[claude-code] $*"; }
log "Stopping and removing Claude Code..."
bash "&plgPATH;/rc.claude-code" stop
rm -rf "&plgPATH;/persist"
sed -i '/rc.claude-code/d' /boot/config/go 2>/dev/null
log "Claude Code removed."
</INLINE>
</FILE>

<!-- POST-INSTALL: verify checksum, install package, hook /boot/config/go -->
<FILE Run="/bin/bash">
<INLINE>
SUM1=$(md5sum "&plgPATH;/&plgNAME;.txz" | awk '{print $1}')
SUM2=$(cat "&plgPATH;/&plgNAME;.md5")
if [ "$SUM1" != "$SUM2" ]; then
  echo "ERROR: Package checksum mismatch - aborting"
  rm -f "&plgPATH;/&plgNAME;.txz" "&plgPATH;/&plgNAME;.md5"
  exit 1
fi

upgradepkg --install-new "&plgPATH;/&plgNAME;.txz"

GO="/boot/config/go"
grep -q "rc.claude-code" "$GO" 2>/dev/null || {
  echo "" >> "$GO"
  echo "# Claude Code - restore symlinks on boot" >> "$GO"
  echo "bash /boot/config/plugins/claude-code/rc.claude-code start" >> "$GO"
}

bash "&plgPATH;/rc.claude-code" start
echo ""
echo "-----------------------------------------------------------"
echo " claude-code plugin installed successfully."
echo " Go to Settings > Claude Code to install Claude Code."
echo "-----------------------------------------------------------"
</INLINE>
</FILE>

<!-- REMOVE -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
bash &plgPATH;/uninstall-claude.sh
removepkg &plgPATH;/&plgNAME;.txz 2>/dev/null
rm -rf &emhttp;
rm -f &plgPATH;/&plgNAME;.txz &plgPATH;/&plgNAME;.md5
rm -f &plgPATH;/rc.claude-code &plgPATH;/install-claude.sh &plgPATH;/uninstall-claude.sh
echo "claude-code: removed."
</INLINE>
</FILE>

</PLUGIN>
